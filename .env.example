# Database connection (required)
DATABASE_URL=postgres://postgres:your_password@localhost:5432/hot_search_db

# AI API Keys (set the one matching ai.provider in melonscout.config.json)
DOUBAO_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# Scraper API Keys (set the ones matching scraper.apiKeyEnv in config)
TIANAPI_API_KEY=

# Internal API key for admin-only routes (e.g. POST/GET /api/weibo-hot). Request header: X-Internal-Key: <value>
# Leave empty to disable internal routes (they respond 503). Set when using a backend admin.
INTERNAL_API_KEY=

# All non-secret configuration is in melonscout.config.json
