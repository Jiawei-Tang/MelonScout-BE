# Database
DATABASE_URL=postgres://postgres:your_password@localhost:5432/hot_search_db

# AI Provider: "google" | "openai" | "deepseek" | "minimax"
AI_PROVIDER=google

# Google AI (Gemini) API Key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# OpenAI API Key (if using OpenAI as AI_PROVIDER)
OPENAI_API_KEY=

# DeepSeek API Key (if using DeepSeek as AI_PROVIDER)
DEEPSEEK_API_KEY=

# MiniMax API Key (if using MiniMax as AI_PROVIDER)
MINIMAX_API_KEY=

# Scraper source: "vvhan" | "cheerio" | "placeholder" | "tianapi"
SCRAPER_SOURCE=vvhan

# 天行数据 API Key（微博热搜等，SCRAPER_SOURCE=tianapi 或 GET /api/weibo-hot 时使用）
TIANAPI_API_KEY=

# Phase 1: only score top N titles per scrape (0 = score all)
ANALYSIS_TOP_N=10

# Phase 2: score threshold to trigger deep analysis (0-100)
DEEP_ANALYSIS_THRESHOLD=60

# Phase 2: max items to deep-analyze per batch (saves tokens)
DEEP_ANALYSIS_MAX=5

# Server
PORT=3000

# Cron schedule for scraping (default: every 15 minutes)
CRON_SCHEDULE=*/15 * * * *
