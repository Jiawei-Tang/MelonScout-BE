# Database
DATABASE_URL=postgres://postgres:your_password@localhost:5432/hot_search_db

# AI Provider: "google" | "openai" | "deepseek"
AI_PROVIDER=google

# Google AI (Gemini) API Key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# OpenAI API Key (optional, if using OpenAI)
OPENAI_API_KEY=

# DeepSeek API Key (optional, if using DeepSeek)
DEEPSEEK_API_KEY=

# Server
PORT=3000

# Cron schedule for scraping (default: every 15 minutes)
CRON_SCHEDULE=*/15 * * * *
