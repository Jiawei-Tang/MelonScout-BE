# Database
DATABASE_URL=postgres://postgres:your_password@localhost:5432/hot_search_db

# AI Provider: "google" | "openai" | "deepseek" | "minimax"
AI_PROVIDER=google

# Google AI (Gemini) API Key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# OpenAI API Key (if using OpenAI as AI_PROVIDER)
OPENAI_API_KEY=

# DeepSeek API Key (if using DeepSeek as AI_PROVIDER)
DEEPSEEK_API_KEY=

# MiniMax API Key (if using MiniMax as AI_PROVIDER)
MINIMAX_API_KEY=

# Scraper source: "cheerio" | "placeholder" | "tianapi"
SCRAPER_SOURCE=tianapi

# 天行数据 API Key
TIANAPI_API_KEY=

# Phase 1 triage: only triage top N titles per scrape (0 = triage all)
ANALYSIS_TOP_N=10

# Phase 2 fact-check: max items to fact-check per batch
DEEP_ANALYSIS_MAX=5

# Server
PORT=3000

# Cron schedule (default: every 15 minutes)
CRON_SCHEDULE=*/15 * * * *

# Startup: fetch if last data is older than this (hours)
STARTUP_FETCH_THRESHOLD_HOURS=1
