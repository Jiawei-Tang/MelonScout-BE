# Database
DATABASE_URL=postgres://postgres:your_password@localhost:5432/hot_search_db

# AI Provider: "google" | "openai" | "deepseek" | "minimax" | "doubao"
AI_PROVIDER=doubao

# Google AI (Gemini) API Key
GOOGLE_AI_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# DeepSeek API Key
DEEPSEEK_API_KEY=

# MiniMax API Key
MINIMAX_API_KEY=

# 豆包 (Doubao / 火山方舟) API Key + Model
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# Scraper source: "cheerio" | "placeholder" | "tianapi"
SCRAPER_SOURCE=tianapi

# 天行数据 API Key
TIANAPI_API_KEY=

# Phase 1 triage: only triage top N titles per scrape (0 = triage all)
ANALYSIS_TOP_N=10

# Phase 2 fact-check: max items to fact-check per batch
DEEP_ANALYSIS_MAX=5

# Server
PORT=3000

# Cron schedule
CRON_SCHEDULE=0 */12 * * *

# Startup: fetch if last data is older than this (hours)
STARTUP_FETCH_THRESHOLD_HOURS=6
